  dialogPieces:
  - ID: Noah
    image: {fileID: -855298285791758126, guid: 81d59856c6b68d14a8d3279fb1231e5e, type: 3}
    text: "\u2026\u2026"
  - ID: Noah
    image: {fileID: -855298285791758126, guid: 81d59856c6b68d14a8d3279fb1231e5e, type: 3}
    text: "It\u2019s her handwriting."
  - ID: Noah
    image: {fileID: 6937817954938267909, guid: 75e8005250a27c04386bf060f8e731fc, type: 3}
    text: I recognize this paper.
  - ID: Noah
    image: {fileID: 5503601100735391139, guid: b76abf6cea25fbc4c811a4099ea1b24a, type: 3}
    text: "This paper\u2026 the edges look like they could be cut."
  - ID: Noah
    image: {fileID: -6470460504253458178, guid: 6a6bd0dba60404a4abe76b8e2ee510e4, type: 3}
    text: "That night\u2026"
  - ID: Noah
    image: {fileID: -6470460504253458178, guid: 6a6bd0dba60404a4abe76b8e2ee510e4, type: 3}
    text: She left this behind and went out.
  - ID: Noah
    image: {fileID: 6937817954938267909, guid: 75e8005250a27c04386bf060f8e731fc, type: 3}
    text: I thought it was just something she said in the heat of the moment.
