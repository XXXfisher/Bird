  dialogPieces:
  - ID: Noah
    image: {fileID: -4178046375966092550, guid: af199fb0ea3a691498b0c8982fcab74b, type: 3}
    text: "\u2026You\u2019re here again."
  - ID: Noah
    image: {fileID: -4178046375966092550, guid: af199fb0ea3a691498b0c8982fcab74b, type: 3}
    text: "There\u2019s another letter today too."
  - ID: Noah
    image: {fileID: -6470460504253458178, guid: 6a6bd0dba60404a4abe76b8e2ee510e4, type: 3}
    text: "I\u2019ve started waiting for you to appear."
  - ID: Noah
    image: {fileID: -4178046375966092550, guid: af199fb0ea3a691498b0c8982fcab74b, type: 3}
    text: "It feels like\u2026 as long as you come,"
  - ID: Noah
    image: {fileID: -855298285791758126, guid: 81d59856c6b68d14a8d3279fb1231e5e, type: 3}
    text: I can remember a little more of her.
