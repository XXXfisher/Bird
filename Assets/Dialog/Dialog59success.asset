  dialogPieces:
  - ID: Noah
    image: {fileID: -855298285791758126, guid: 81d59856c6b68d14a8d3279fb1231e5e, type: 3}
    text: "Still here\u2026"
  - ID: Noah
    image: {fileID: -855298285791758126, guid: 81d59856c6b68d14a8d3279fb1231e5e, type: 3}
    text: with you.
  - ID: Noah
    image: {fileID: -4178046375966092550, guid: af199fb0ea3a691498b0c8982fcab74b, type: 3}
    text: "\u2026You came."
  - ID: Noah
    image: {fileID: -6470460504253458178, guid: 6a6bd0dba60404a4abe76b8e2ee510e4, type: 3}
    text: "The one who\u2019s been bringing all these letters\u2026"
  - ID: Noah
    image: {fileID: -855298285791758126, guid: 81d59856c6b68d14a8d3279fb1231e5e, type: 3}
    text: "it was you, wasn\u2019t it?"
  - ID: Noah
    image: {fileID: -6470460504253458178, guid: 6a6bd0dba60404a4abe76b8e2ee510e4, type: 3}
    text: "That white bird\u2026"
  - ID: Noah
    image: {fileID: 4130640169021434097, guid: 692a39cfa42d55d44b4c51e3c4d67d79, type: 3}
    text: was that you, Elena?
  - ID: Noah
    image: {fileID: -4178046375966092550, guid: af199fb0ea3a691498b0c8982fcab74b, type: 3}
    text: "\u2026Please, tell me."
