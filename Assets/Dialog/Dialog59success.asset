  dialogPieces:
  - ID: Noah
    image: {fileID: 0}
    text: "Still here\u2026"
  - ID: Noah
    image: {fileID: 0}
    text: with you.
  - ID: Noah
    image: {fileID: 0}
    text: "\u2026You came."
  - ID: Noah
    image: {fileID: 0}
    text: "The one who\u2019s been bringing all these letters\u2026"
  - ID: Noah
